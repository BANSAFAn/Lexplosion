<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://xamarin.com/schemas/2014/forms"
    xmlns:controls="clr-namespace:Lexplosion.WPF.NewInterface.Controls;assembly=LexplosionAvalonia"
    xmlns:converters="clr-namespace:Lexplosion.WPF.NewInterface.Core.Converters;assembly=LexplosionAvalonia"
    xmlns:extensions="clr-namespace:Lexplosion.WPF.NewInterface.Extensions;assembly=LexplosionAvalonia"
    xmlns:header="clr-namespace:Lexplosion.WPF.NewInterface.WindowComponents.Header;assembly=LexplosionAvalonia"
    xmlns:message="clr-namespace:Lexplosion.WPF.NewInterface.Controls.Message.Core;assembly=LexplosionAvalonia"
    xmlns:notification="clr-namespace:Lexplosion.WPF.NewInterface.Core.Notifications;assembly=LexplosionAvalonia"
    xmlns:objects="clr-namespace:Lexplosion.WPF.NewInterface.Core.Objects;assembly=LexplosionAvalonia"
    xmlns:pages="clr-namespace:Lexplosion.WPF.NewInterface.Mvvm.Views.Pages;assembly=LexplosionAvalonia"
    xmlns:runtime="clr-namespace:Lexplosion.WPF.NewInterface;assembly=LexplosionAvalonia"
    xmlns:viewmodels="clr-namespace:Lexplosion.WPF.NewInterface.Mvvm.ViewModels;assembly=LexplosionAvalonia"
    x:Class="LexplosionAvalonia.Mvvm.Views.Windows.MainWindow"
    Title="Lexplosion"
    Width="944"
    Height="528"
    MinWidth="944"
    MinHeight="528"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="-1">

    

    

    <Window.Styles>
        <DataTemplate DataType="{x:Type objects:InstanceNotification}">
            <Border
                Padding="16,8,8,8"
                BorderBrush="{DynamicResource SeparateSolidColorBrush}"
                BorderThickness="0,1,0,1">
                <Grid HorizontalAlignment="Left">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Logo or Icon  -->
                    <Border
                        Width="40"
                        Height="40"
                        VerticalAlignment="Top"
                        Background="{DynamicResource ActivitySolidColorBrush}"
                        CornerRadius="5" />

                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <!--  Title  -->
                        <TextBlock
                            FontSize="14"
                            FontWeight="Medium"
                            Foreground="{DynamicResource PrimaryForegroundSolidColorBrush}"
                            Text="{Binding Title}" />

                        <!--  Content  -->
                        <TextBlock
                            Margin="0,4,0,0"
                            Foreground="{DynamicResource PrimaryForegroundSolidColorBrush}"
                            Text="{Binding Content}"
                            TextWrapping="WrapWithOverflow" />

                        <!--  Time  -->
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Foreground="{DynamicResource SecondaryForegroundSolidColorBrush}" Text="{Binding Time}" />

                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Foreground="{DynamicResource SecondaryForegroundSolidColorBrush}"
                                Text="{Binding InstanceName, StringFormat=(in {0})}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Styles>

    <!--
        Width="350"
        Height="470"
    -->

    <Design.DataContext>
    <viewmodels:MainViewModel/>
</Design.DataContext>
<Grid>

        <Grid
    x:Name="ContainerGrid"
    Background="{DynamicResource SecondarySolidColorBrush}"
    RenderTransformOrigin="0.5, 0.5">

            <!--  Content  -->
            <!--  IsEnabled="{Binding IsModalOpen, Converter={converters:NegativeBooleanValueConverter}, Source={StaticResource MainViewModel}}"  -->
            <ContentControl Content="{Binding CurrentViewModel}" />

            <!--<pages:WelcomeView />-->

            <!--  Modal Control  -->
            <controls:ModalControl
                Content="{Binding CurrentModalViewModel}"
                IsOpen="{Binding IsModalOpen}" />

            <!--  Window Header Panel Margin="16,12"  -->
            <header:WindowHeaderContainer
                x:Name="HeaderContainer"
                Height="40"
                VerticalAlignment="Top"
                HeaderType="WindowsOS" />

            <!--  Toast Message Notification Panel  -->
            <ItemsControl
                Height="300"
                Margin="0,22,-14,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                ItemsSource="{Binding AppCore.NotificationService.Notifications}">

                <ItemsControl.Resources>

                    <DataTemplate DataType="{x:Type notification:SimpleNotification}">
                        <controls:ToastMessage
                            Title="{Binding Title}"
                            CloseCommand="{Binding CloseCommand}"
                            Message="{Binding Content}"
                            State="Notification"
                            VisibilityTime="{Binding VisibleTime}" />
                    </DataTemplate>

                </ItemsControl.Resources>

            </ItemsControl>

            <Grid
                x:Name="AddtionalFuncs"
                Margin="16,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                RenderTransformOrigin="0.5, 0.5"
                Visibility="Collapsed">

                <StackPanel HorizontalAlignment="{Binding HorizontalAlignment, ElementName=AddtionalFuncs}" Orientation="Horizontal">
                    <!--  Ожидается добавление realtime обновлений  -->
                    <!--  Notifications  -->
                    <ToggleButton
                        x:Name="notify"
                        Margin="0,0,0,0"
                        Visibility="Collapsed">
                        <ToggleButton.Template>
                            <ControlTemplate>
                                <Border
                                    Width="20"
                                    Height="20"
                                    Padding="2"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource SeparateSolidColorBrush}"
                                    CornerRadius="2">

                                    <Grid>
                                        <Viewbox Height="16">
                                            <Path
                                                Data="M160-200v-80h80v-280q0-83 50-147.5T420-792v-28q0-25 17.5-42.5T480-880q25 0 42.5 17.5T540-820v28q80 20 130 84.5T720-560v280h80v80H160Zm320-300Zm0 420q-33 0-56.5-23.5T400-160h160q0 33-23.5 56.5T480-80ZM320-280h320v-280q0-66-47-113t-113-47q-66 0-113 47t-47 113v280Z"
                                                Fill="{DynamicResource ActivitySolidColorBrush}"
                                                Stretch="Fill" />
                                        </Viewbox>

                                        <Border
                                            Width="6"
                                            Height="6"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Background="Red"
                                            BorderBrush="{DynamicResource SeparateSolidColorBrush}"
                                            BorderThickness="1"
                                            CornerRadius="50" />
                                    </Grid>
                                    <Border.ToolTip>

                                        <controls:AdvancedToolTip
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Placement="Left"
                                            PlacementRectangle="-10,-15,0,0">

                                            <TextBlock
                                                Padding="15,14,15,14"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="Medium"
                                                Foreground="{DynamicResource CheckBoxMarkSolidColorBrush}"
                                                Text="{DynamicResource Notifications}" />
                                        </controls:AdvancedToolTip>
                                    </Border.ToolTip>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!--  Change Panel Orintation  -->

                    <Border
                        Width="20"
                        Height="20"
                        Margin="8,0,0,0"
                        Padding="2"
                        Background="{DynamicResource SeparateSolidColorBrush}"
                        CornerRadius="2"
                        PointerPressed="Border_MouseDown_2"
                        ToolTip.Tip="Изменить положение меню"
                        ToolTip.Placement="Bottom">
                        <Viewbox Height="14">
                            <Path
                                extensions:PathExtensions.StringKeyData="IndentDecrease"
                                Fill="{DynamicResource ActivitySolidColorBrush}"
                                Stretch="Fill" />
                        </Viewbox>
                    </Border>


                    <!--  Change Scale  -->

                    <Border
                        Width="20"
                        Height="20"
                        Margin="8,0,0,0"
                        Padding="2"
                        Background="{DynamicResource SeparateSolidColorBrush}"
                        CornerRadius="2"
                        PointerPressed="ScaleFit_MouseDown"
                        ToolTip.Tip="Масштабировать"
                        ToolTip.Placement="Bottom">

                        <Viewbox Height="14">
                            <Path
                                extensions:PathExtensions.StringKeyData="ScaleFit"
                                Fill="{DynamicResource ActivitySolidColorBrush}"
                                Stretch="Fill" />
                        </Viewbox>
                    </Border>
                </StackPanel>

                <!--  Notification Window  -->
                <Border
                    Width="350"
                    Height="300"
                    Margin="0,24,0,0"
                    Background="{DynamicResource PrimarySolidColorBrush}"
                    BorderBrush="{DynamicResource SeparateSolidColorBrush}"
                    BorderThickness="1"
                    CornerRadius="5"
                    IsVisible="{Binding $parent[ToggleButton].IsChecked}">

                    <Border.BoxShadow>
                        <BoxShadows>0 0 10 0 #1A000000</BoxShadows>
                    </Border.BoxShadow>

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="16,8">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Medium"
                                Foreground="{DynamicResource PrimaryForegroundSolidColorBrush}"
                                Text="Your Notification" />
                        </Grid>

                        <ScrollViewer Grid.Row="1">
                            <ItemsControl Margin="0,0,0,0" Background="Transparent" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid
                Margin="16,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="Transparent">

                

                <ItemsControl
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ItemsSource="{Binding Source={StaticResource Messages}}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.Resources>

                        <DataTemplate DataType="{x:Type message:MessageItemModel}">
                            <controls:MessageItem
                                Margin="0,0,0,16"
                                Text="{Binding Text}"
                                Type="{Binding Type}" />
                        </DataTemplate>

                    </ItemsControl.Resources>
                </ItemsControl>
            </Grid>

            <!--  Image Overview  -->

            <Border x:Name="ImageViewer" Padding="16" IsVisible="False">
                <Border.Background>
                    <SolidColorBrush Opacity="0.6" Color="Black" />
                </Border.Background>
                <Grid>
                    <Border CornerRadius="5">
                        <Border.Background>
                            <ImageBrush x:Name="Image" />
                        </Border.Background>
                    </Border>

                    <Border
                        Margin="0,0,0,-12"
                        Padding="16,8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Background="{DynamicResource PrimarySolidColorBrush}"
                        BorderBrush="{DynamicResource SeparateSolidColorBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <StackPanel Orientation="Horizontal">

                            <controls:AdvancedButton
                                x:Name="CloseImage"
                                Width="32"
                                Height="32"
                                Margin="0,0,0,0"
                                IconData="{DynamicResource PDClose}"
                                Style="{StaticResource sm-button-icon}"
                                ToolTip="{DynamicResource Close}" />
                            <!--<controls:AdvancedButton
                                x:Name="PrevImage"
                                Width="32"
                                Height="32"
                                IconData="{DynamicResource PDLeftBackArrow}"
                                Style="{StaticResource sm-button-icon}" />
                            <controls:AdvancedButton
                                x:Name="NextImage"
                                Width="32"
                                Height="32"
                                Margin="8,0,0,0"
                                IconData="{DynamicResource PDLeftBackArrow}"
                                RenderTransformOrigin="0.5,0.5"
                                Style="{StaticResource sm-button-icon}">
                                <controls:AdvancedButton.RenderTransform>
                                    <RotateTransform Angle="180" />
                                </controls:AdvancedButton.RenderTransform>
                            </controls:AdvancedButton>-->
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!--  Circle Animation Block  -->
            <Grid x:Name="PaintArea">
                <Grid.RenderTransform>
                    <TranslateTransform X="0" Y="0" />
                </Grid.RenderTransform>
                <Grid.Clip>
                    <EllipseGeometry x:Name="CircleReveal" Center="101,22" />
                </Grid.Clip>
            </Grid>

            <controls:LoadingBoard
                Background="Black"
                Opacity="0.8"
                IsVisible="{Binding GlobalLoadingArgs.State}"
                Placeholder="{Binding GlobalLoadingArgs.ProcessDescription}" />
        </Grid>
    </Grid>
</Window>
